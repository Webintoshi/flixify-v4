# ============================================
# Flixify Production Environment Variables
# ============================================

# Server Configuration
NODE_ENV=production
PORT=9199

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase Configuration
SUPABASE_URL=https://vohisilzyxzmjdsalgea.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Backward-compatible alias also supported by the server:
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# M3U Provider
M3U_PROVIDER_URL=http://sifiriptvdns.com:80/playlist/
PLAYLIST_DELIVERY_MODE=hybrid

# CORS (Frontend URLs)
CORS_ORIGINS=https://flixify.pro,https://app.flixify.pro

# Optional: Email Configuration (for notifications)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Optional: Payment Integration
# PAYMENT_API_KEY=
# PAYMENT_API_SECRET=

# Telegram Bot (Admin Control)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change_this_to_long_random_secret
TELEGRAM_WEBHOOK_URL=https://api.your-domain.com/api/v1/telegram/webhook/change_this_to_long_random_secret
TELEGRAM_WEBHOOK_HEADER_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_NOTIFICATION_CHAT_IDS=
TELEGRAM_BOT_ADMIN_ID=
TELEGRAM_EXPIRY_ALERT_DAYS=3
TELEGRAM_EXPIRY_ALERT_INTERVAL_MS=3600000
