# =============================================================================
# IPTV ANONYM PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# -----------------------------------------------------------------------------
# JWT Secret - Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_different_from_above

# Bcrypt/Encryption
ENCRYPTION_KEY=your_32_char_encryption_key_here

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
# Backward-compatible alias also supported:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION (for token caching and rate limiting)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://flixify.pro,https://app.flixify.pro

# -----------------------------------------------------------------------------
# PROXY CONFIGURATION
# -----------------------------------------------------------------------------
PROXY_TIMEOUT_MS=30000
PROXY_MAX_REDIRECTS=5
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# -----------------------------------------------------------------------------
# OBSERVABILITY
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true
CORRELATION_ID_HEADER=x-request-id

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_SWAGGER=true
ENABLE_METRICS=true
PLAYLIST_DELIVERY_MODE=hybrid

# -----------------------------------------------------------------------------
# TELEGRAM BOT (ADMIN CONTROL)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change_this_to_long_random_secret
TELEGRAM_WEBHOOK_URL=https://api.your-domain.com/api/v1/telegram/webhook/change_this_to_long_random_secret
TELEGRAM_WEBHOOK_HEADER_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_NOTIFICATION_CHAT_IDS=
TELEGRAM_BOT_ADMIN_ID=
TELEGRAM_EXPIRY_ALERT_DAYS=3
TELEGRAM_EXPIRY_ALERT_INTERVAL_MS=3600000
